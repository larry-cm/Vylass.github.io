---
import Image from "astro/components/Image.astro";

interface Props {
    userName: string;
    userImg: string;
}
const { userName, userImg } = Astro.props;
---

<section class="flex size-full rounded border border-slate-50">
    <input type="checkbox" class="peer hidden" id="menuBar" />
    <aside
        class="flex flex-col transition-all w-15 peer-checked:w-52 h-full px-5 py-8 overflow-y-auto bg-[#1a1a1a] border-r rtl:border-r-0 rtl:border-l overflow-hidden"
    >
        <label for="menuBar" class="flex items-center space-x-4 w-fit">
            <Image width={24} height={24} src="/logo.svg" alt="" />
            <em class="not-italic font-medium text-xl">Dashboard</em>
        </label>

        <div class="flex flex-col justify-between flex-1 mt-6">
            <nav class="flex-1 -mx-3 space-y-3">
                <!-- <div class="relative mx-3">
                    <span
                        class="absolute inset-y-0 left-0 flex items-center pl-3"
                    >
                        <svg
                            class="w-5 h-5 text-gray-400"
                            viewBox="0 0 24 24"
                            fill="none"
                        >
                            <path
                                d="M21 21L15 15M17 10C17 13.866 13.866 17 10 17C6.13401 17 3 13.866 3 10C3 6.13401 6.13401 3 10 3C13.866 3 17 6.13401 17 10Z"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path>
                        </svg>
                    </span>

                    <input
                        type="text"
                        class="w-full py-1.5 pl-10 pr-4 text-slate-100 bg-black border rounded-md focus:border-orange-400 outline-none"
                        placeholder="Search"
                    />
                </div> -->

                <a
                    class="flex items-center px-3 py-2 text-slate-50 transition-colors duration-300 transform rounded-lg hover:bg-orange-500 hover:text-slate-100"
                    href="#"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                        stroke="currentColor"
                        class="min-w-6 w-6"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
                        ></path>
                    </svg>

                    <span class="mx-4 text-sm font-medium">Home</span>
                </a>

                <a
                    class="flex items-center px-3 py-2 text-slate-50 transition-colors duration-300 transform rounded-lg hover:bg-orange-500 hover:text-slate-100"
                    href="#"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                        stroke="currentColor"
                        class="min-w-6 w-6"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"
                        ></path>
                    </svg>

                    <span class="mx-4 text-sm font-medium">Users</span>
                </a>

                <a
                    class="flex items-center px-3 py-2 text-slate-50 transition-colors duration-300 transform rounded-lg hover:bg-orange-500 hover:text-slate-100"
                    href="#"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                        stroke="currentColor"
                        class="min-w-6 w-6"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 011.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.56.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.893.149c-.425.07-.765.383-.93.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 01-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.397.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 01-.12-1.45l.527-.737c.25-.35.273-.806.108-1.204-.165-.397-.505-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.107-1.204l-.527-.738a1.125 1.125 0 01.12-1.45l.773-.773a1.125 1.125 0 011.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894z"
                        ></path>
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>

                    <span class="mx-4 text-sm font-medium">Setting</span>
                </a>
            </nav>

            <div>
                <div class="flex items-center justify-between mt-6">
                    <a href="#" class="flex items-center space-x-4">
                        <Image
                            width={24}
                            height={24}
                            class="object-cover rounded-full"
                            src={userImg ??
                                "https://images.unsplash.com/photo-1531427186611-ecfd6d936c79?ixid=MXwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHw%3D&ixlib=rb-1.2.1&auto=format&fit=crop&w=634&h=634&q=80"}
                            alt="avatar"
                        />
                        <span
                            class="text-sm font-medium w-24 truncate text-gray-700 dark:text-gray-200"
                            >{userName ?? "John Doe"}</span
                        >
                    </a>

                    <a
                        href="#"
                        class="text-slate-100 transition-colors duration-200 rotate-180 rtl:rotate-0 ms-2 hover:text-orange-500"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-5 h-5"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"
                            ></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </aside>
    <article class=""></article>
</section>
