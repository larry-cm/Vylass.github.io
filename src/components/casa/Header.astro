---
import { Image } from "astro:assets";
import Logo from "/public/logo.svg";
export const prerender = false;
function addItems(l: string[], l2: string[]) {
    return l.map((e, i, m) => ({ text: m[i], url: l2[i] }));
}
const entrada = addItems(
    ["Plataforma", "Registro de usuarios"],
    ["/", "registro"],
);
---

<header
    class="header relative min-h-[10vh] flex justify-between items-center bg-gradient-to-br from-orange-600/90 to-orange-400 z-20"
>
    <nav
        transition:name={`nav-base`}
        class="px-4 h-full w-full flex justify-between items-center"
    >
        <a href="/" class="min-w-[28%] flex items-center">
            <Image
                src={Logo}
                alt="foto del icono"
                loading="eager"
                width={60}
                height={60}
            />
            <h1
                class="text-2xl md:text-3xl lg:text-4xl font-semibold first-letter:text-3xl first-letter:md:text-4xl first-letter:lg:text-5xl first-letter:capitalize text-nowrap"
            >
                fetchToMySQL
            </h1>
        </a>

        <!-- menu de aburguesa -->
        <input type="checkbox" id="btn-burger" class="peer hidden" />
        <label class="" for="btn-burger">
            <span class="sr-only">Menu de hamburguesa para los celulares</span>
            <span class="sm:hidden">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="30"
                    height="30"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    ><path stroke="none" d="M0 0h24v24H0z" fill="none"
                    ></path><path
                        d="M18 3a3 3 0 0 1 2.995 2.824l.005 .176v12a3 3 0 0 1 -2.824 2.995l-.176 .005h-12a3 3 0 0 1 -2.995 -2.824l-.005 -.176v-12a3 3 0 0 1 2.824 -2.995l.176 -.005h12zm0 2h-12a1 1 0 0 0 -.993 .883l-.007 .117v9h14v-9a1 1 0 0 0 -.883 -.993l-.117 -.007zm-7.387 3.21l.094 .083l1.293 1.292l1.293 -1.292a1 1 0 0 1 1.32 -.083l.094 .083a1 1 0 0 1 .083 1.32l-.083 .094l-2 2a1 1 0 0 1 -1.32 .083l-.094 -.083l-2 -2a1 1 0 0 1 1.32 -1.497z"
                    ></path></svg
                >
            </span>
        </label>
        <ul
            class="dark:text-black text-black hidden peer-checked:sm:hidden peer-checked:flex justify-center space-x-4 items-center bg-gradient-to-l from-slate-50 to-slate-200 absolute top-[100%] right-0 mx-auto left-0 h-12"
        >
            {
                entrada.map((e) => (
                    <li class=" hover:text-slate-500 text-base font-medium">
                        {/* {exist && e.url.match("inicio-de-sesion") ? (
                            <a href="verifyUsers/logout">Cerrar Sesión</a>
                        ) : (
                            <a href={e.url}>{e.text}</a>
                        )} */}
                    </li>
                ))
            }
        </ul>
        <!-- menu principal -->
        <ul
            class="sm:flex max-h-[60px] justify-end flex-col sm:gap-2 md:gap-5 lg:gap-8 me-[10px] sm:flex-row items-center transition text-center hidden *:md:text-xl *:text-nowrap *:font-normal *:lg:text-xl *:cursor-pointer"
        >
            {
                entrada.map(({ url, text }) => {
                    if (url === "registro")
                        return (
                            <li class="text-white hover:text-slate-900">
                                <a href={url}>{text}</a>
                            </li>
                        );
                    return (
                        <li class="text-black hover:text-slate-500">
                            <a href={url}>{text}</a>
                        </li>
                    );
                })
            }
        </ul>
    </nav>
</header>
<style>
    .header nav {
        span svg {
            transform: rotate(-90deg);
            transition: 0.2s ease;
        }
        #btn-burger:checked + label span svg {
            transform: rotate(0deg);
        }
        ul li {
            transition: 0.3s ease;
        }
    }
</style>
