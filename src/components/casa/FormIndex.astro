---
import { turso } from "@bd/configTurso";
import Action from "@components/casa/Action";
let errorMsg = {
    exist: true,
    message: "",
};

if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    const userOrEmail = formData.get("user-or-email");
    if (!userOrEmail) {
        errorMsg = {
            exist: false,
            message: "No hemos encontrado nada,ese nombre que!",
        };
    }

    if (userOrEmail) {
        // regex para mirar que son
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        const usernameRegex = /^[a-zA-Z0-9_]{3,16}$/;
        // función de pedida de datos a columnas diferentes
        const getRows = async (columnWhere: string) => {
            try {
                const { rows } = await turso.execute({
                    sql: `SELECT user_name FROM users WHERE ${columnWhere} = ?`,
                    args: [userOrEmail.valueOf().toString().trim()],
                });
                console.log(rows);

                return {
                    exist: !!rows.length,
                    user: !!rows.length ? rows[0].user_name : null,
                    message:
                        "Tu usuario no esta registrado en nuestra base por favor regístrate!",
                };
            } catch (error) {
                console.log(error);

                return {
                    exist: false,
                    message:
                        "Al parecer tuvimos un error con la conexión a la base de datos, por favor revisa si estas conectado a internet y vuelve a intentarlo!" +
                        error,
                };
            }
        };
        if (userOrEmail.valueOf().toString().match(emailRegex)) {
            // consulta sql
            errorMsg = await getRows("user_email");
        } else if (userOrEmail.valueOf().toString().match(usernameRegex)) {
            errorMsg = await getRows("user_name");
        } else {
            errorMsg = {
                exist: false,
                message: "No hemos encontrado nada,ese nombre que!",
            };
        }
        if (Astro.cookies.has("user")) {
            console.log("existe las cookies");
            // if (errorMsg.exist) await Astro.cookies?.set("user", { name: "jorge" });
        }
        Astro.cookies.set("user", { name: "jorge" });
    }
}
---

<article class="border p-8 flex flex-col bg-[#1a1a1a] rounded-md">
    <h2 class="text-lg sm:text-2xl font-bold capitalize">
        verificación de cuenta
    </h2>
    <form
        class="text-base flex flex-col justify-between h-full *:text-base"
        method="POST"
    >
        <div class="flex flex-col sm:gap-y-3">
            <label for="userName" class="max-w-4/5">
                <h3
                    class="py-2 text-gray-300 font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-base"
                >
                    Nombre de usuario o correo electrónico
                </h3>
            </label>
            <input
                required
                type="text"
                auto-complete="true"
                min={4}
                min-length={4}
                placeholder="Carlota o carlota@gmail.com"
                class="w-full px-4 py-2 rounded bg-gray-800 text-white placeholder:text-slate-300 border border-gray-600 focus:outline-none focus:border-orange-500"
                name="user-or-email"
                id="userName"
            />
            <div
                class="flex flex-col sm:flex-row space-y-2 my-2 sm:my-0 sm:space-y-0 text-sm justify-between *:flex *:items-center *:text-orange-400 *:underline *:underline-offset-2"
            >
                <a href="registro" class="hover:text-orange-400/80"
                    >Regístrate ahora</a
                >
            </div>
        </div>
        <div class="text-center mt-2 sm:mt-4">
            <Action type="submit" text="Continuar" />
        </div>
    </form>

    {
        !errorMsg.exist && (
            <div class="absolute top-13 sm:top-1/12 left-0 right-0 flex flex-col justify-center items-center max-w-[40rem] h-26 mx-4 px-4 sm:mx-auto bg-orange-500/60 before:content-[''] before:size-full before:bg-black/20 before:absolute ">
                <h4 class="text-lg sm:text-xl font-bold text-white mb-2 flex justify-center items-center">
                    ¡Ups! Ha ocurrido un error
                    <span class="ms-2">x</span>
                </h4>
                <p class="text-slate-100 block font-medium text-base sm:text-lg self-start">
                    {errorMsg.message}
                </p>
            </div>
        )
    }
</article>
