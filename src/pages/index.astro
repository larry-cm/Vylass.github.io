---
import "@styles/global.css";
import "@styles/loading.css";
import Layout from "@/layouts/Layout.astro";
import Home from "@components/casa/Home.astro";
import DashBoardIndex from "@components/casa/DashBoardIndex.astro";

const userSession = Astro.cookies.get("sessionIniciada")?.value;
const userImg = Astro.cookies.get("imagenUsuario")?.value;
const userName = Astro.cookies.get("usuario")?.value;
---

<Layout title="Búsquedas de MySQL || FetchToMySQL">
	{
		userSession === "true" ? (
			<DashBoardIndex userImg={userImg ?? ""} userName={userName ?? ""} />
		) : (
			<Home />
		)
	}
</Layout>
