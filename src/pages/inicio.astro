---
import "@/styles/global.css";
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Inicio de sesión de MySQL || FetchToMySQL">
    <!-- Contenido -->
    <article class="flex flex-col items-center justify-center flex-1 px-4">
        <div
            class="border border-white p-8 mt-8 bg-[#1a1a1a] w-full max-w-md rounded-md shadow-lg"
        >
            <h2 class="text-2xl font-bold text-center mb-6">Iniciar Sesión</h2>
            <form>
                <!-- Usuario / Email -->
                <div class="mb-2 text-xl">
                    <p class="font-semibold">
                        ¡Bienvenido de nuevo! Ingresa tu contraseña para acceder
                        a tu cuenta.
                    </p>
                </div>

                <!-- Contraseña -->
                <div class="mb-6">
                    <label for="password" class="block mb-1 font-semibold"
                        >Contraseña</label
                    >
                    <input
                        type="password"
                        id="password"
                        name="password"
                        placeholder="Introduce tu contraseña"
                        class="w-full px-4 py-2 rounded bg-gray-800 text-white border border-gray-600 focus:outline-none focus:border-orange-500 placeholder:text-slate-300"
                    />
                </div>

                <!-- Botón -->
                <button
                    type="submit"
                    class="w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold py-2 rounded transition-colors cursor-pointer"
                >
                    Iniciar Sesión
                </button>
            </form>

            <div class="mt-4 text-center text-sm">
                ¿Olvidaste tu contraseña?
                <a href="#" class="text-orange-400 hover:underline"
                    >Recupérala aquí</a
                >
            </div>
        </div>
    </article>
</Layout>
